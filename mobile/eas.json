{
  "cli": {
    "version": ">= 3.13.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "ios": {
        "image": "default",
        "appleTeamId": "XXXXXXXXXX",
        "bundleIdentifier": "com.capechain.genx",
        "buildCredentials": {
          "provisioningProfile": {
            "method": "app-store"
          }
        },
        "credentialsSource": "auto"
      },
      "android": {
        "image": "default",
        "buildType": "apk",
        "credentialsSource": "auto"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "XXXXXXXXXX",
        "ascAppId": "XXXXXXXXXX"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
